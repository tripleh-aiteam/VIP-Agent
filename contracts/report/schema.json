{
  "$defs": {
    "ReportSection": {
      "properties": {
        "title": {
          "title": "Title",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "data": {
          "anyOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        },
        "charts": {
          "description": "URIs to chart images or data",
          "items": {
            "type": "string"
          },
          "title": "Charts",
          "type": "array"
        }
      },
      "required": [
        "title",
        "content"
      ],
      "title": "ReportSection",
      "type": "object"
    },
    "ReportType": {
      "enum": [
        "daily_summary",
        "weekly_digest",
        "alert",
        "audit",
        "portfolio",
        "custom"
      ],
      "title": "ReportType",
      "type": "string"
    }
  },
  "description": "Intermediate report assembled from task run outputs before finalization.",
  "examples": [
    {
      "report_type": "daily_summary",
      "sections": [
        {
          "content": "Portfolio value increased by 2.3%",
          "title": "Overview"
        },
        {
          "content": "AAPL +5.1%, TSLA -2.0%",
          "title": "Top Movers"
        }
      ],
      "title": "Daily Portfolio Summary \u2014 2026-04-13",
      "trace_id": "tr-20260413-001"
    }
  ],
  "properties": {
    "draft_id": {
      "format": "uuid",
      "title": "Draft Id",
      "type": "string"
    },
    "trace_id": {
      "title": "Trace Id",
      "type": "string"
    },
    "report_type": {
      "$ref": "#/$defs/ReportType"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "source_run_ids": {
      "description": "Task runs that contributed data",
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Source Run Ids",
      "type": "array"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/ReportSection"
      },
      "title": "Sections",
      "type": "array"
    },
    "raw_data": {
      "description": "Unprocessed data for further assembly",
      "title": "Raw Data",
      "type": "object"
    },
    "generated_by": {
      "default": "report-composer",
      "title": "Generated By",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "version": {
      "default": "1.0",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "report_type",
    "title"
  ],
  "title": "ReportDraft",
  "type": "object"
}