# ======================
# VIP AI Platform — Environment Variables
# ======================
# Copy this file to .env and fill in your values.

# --- Database ---
POSTGRES_USER=vip
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=vip_platform
DATABASE_URL=postgresql://vip:YOUR_PASSWORD@localhost:5432/vip_platform

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- API Keys (add when needed) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Telegram (control/notification channel) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Service URLs (for local dev, Docker overrides these) ---
ORCHESTRATOR_URL=http://localhost:8000
GATEWAY_URL=http://localhost:8001
JUDGEMENT_URL=http://localhost:8002
REPORT_COMPOSER_URL=http://localhost:8003
DASHBOARD_URL=http://localhost:3000

# --- CORS (comma-separated origins, empty = allow all) ---
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://vip-agent-dashboard.vercel.app

# --- General ---
APP_ENV=development
LOG_LEVEL=debug
