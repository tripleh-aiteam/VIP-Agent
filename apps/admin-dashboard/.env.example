# ============================================
# VIP Agent Platform — Frontend Environment
# ============================================
# Copy to .env.local for local dev.
# Set these in Vercel Project Settings for deployment.

# --- Required ---

# Backend API URL (required)
# Local: http://localhost:8000
# Preview: https://your-staging-backend.example.com
# Production: https://api.vip-agent.example.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Optional ---

# Environment label (shown in debug, not user-facing)
# Values: development | preview | production
NEXT_PUBLIC_APP_ENV=development

# Supabase public URL (only if frontend needs direct Supabase access)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (public, safe for browser — NOT the service role key)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ============================================
# WARNING: Never put these in the frontend:
# - SUPABASE_SERVICE_ROLE_KEY
# - OPENAI_API_KEY
# - DATABASE_URL
# - TELEGRAM_BOT_TOKEN
# - Any secret key or password
# ============================================
