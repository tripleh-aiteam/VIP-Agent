{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "VIP Agent default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "core:window:allow-set-title",
      "allow": true
    }
  ],
  "remote": {
    "urls": [
      "https://oasisvip.vercel.app/*",
      "https://vip-orchestrator.onrender.com/*"
    ]
  }
}
